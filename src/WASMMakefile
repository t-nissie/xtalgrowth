#-*-Makefile-*- for WebAssembly（WASM) version of xtalgrowth
##
CC=emcc
wasm_canvas_dir = /Users/takeshi/wasm/wasm-canvas
xtalgrowth.html: template.html WASMsim.o sim_core.o canvas.o uni64.o hashpjw.o
	emcc --shell-file $^ -o $@
	emrun $@
#	emrun --browser=/Applications/Safari.app/Contents/MacOS/Safari --kill_exit $@

canvas.%: $(wasm_canvas_dir)/src/canvas.%
	ln -s $< .

canvas.o: canvas.c canvas.h

clean:
	rm -f canvas.o hello.o index.html index.js index.wasm
